<?xml version="1.0" encoding="UTF-8" standalone="no"?>

<simulation>

  <geometry dim="2" X0="-0.5 -0.5">
    <refine patch="1" u="31" v="31"/>
    <topologysets>
      <set name="vertical" type="edge">
        <item patch="1">1 2</item>
      </set>
      <set name="horizontal" type="edge">
        <item patch="1">3 4</item>
      </set>
    </topologysets>
  </geometry>

  <darcycorrection>
    <boundaryconditions>
      <dirichlet set="vertical"   comp="1" type="expression">1-2*y</dirichlet>
      <dirichlet set="horizontal" comp="2" type="expression">2*x</dirichlet>
    </boundaryconditions>
    <input_velocity type="expression">1-2*y|2*x</input_velocity>
    <observed_concentration type="expression">1-(x-t)^2</observed_concentration>
    <input_source type="expression">4*y*(x-t)</input_source>
    <penalty alpha="1.0" beta="1.0" eps="0.0"/>
  </darcycorrection>

  <timestepping start="0" end="1" dt="0.1" type="be"/>

</simulation>
